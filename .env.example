SMTP_HOST=mail.tudominio.com
SMTP_PORT=587
SMTP_USER=usuario@tudominio.com
SMTP_PASS=tu_password
MAIL_FROM="Control Risk <no-reply@tudominio.com>"
MAIL_TO=contacto@tudominio.com
# Opcional en lugar de MAIL_TO:
# MAIL_TO_ENCRYPTED=<iv_base64>:<cipher_base64>:<tag_base64>
# MAIL_TO_KEY=<clave-larga-y-unica>
# Opcional para restringir origenes (coma separada):
# ALLOWED_ORIGINS=https://controlrisk-seguridad.netlify.app,https://www.tudominio.com
# Opcional para rate limit:
# RATE_LIMIT_WINDOW_MS=600000
# RATE_LIMIT_MAX=12
